<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/glass_bg_gradient"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:gravity="center_horizontal"
    android:layoutAnimation="@anim/layout_animation_fade_up"
    android:keepScreenOn="true"
    android:orientation="vertical"
    tools:context=".HorofActivity">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/videoLayout1"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_gravity="center"
        android:layout_marginHorizontal="24dp"
        android:layout_marginVertical="16dp"
        android:layout_weight="2.3"
        app:cardBackgroundColor="@color/glass_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1.5dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@android:color/transparent">

            <androidx.media3.ui.PlayerView
                android:id="@+id/HorofVideoView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_gravity="center"
                app:resize_mode="fit"
                app:surface_type="texture_view"
                app:shutter_background_color="@android:color/transparent"
                app:use_controller="true"
                app:show_timeout="1000"
                app:auto_show="false" />
        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.8"
        android:gravity="center"
        android:orientation="vertical">


        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewHorof"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:clipToPadding="false"
            android:orientation="horizontal"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_horof" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/settingsCard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginHorizontal="20dp"
        android:layout_marginVertical="30dp"
        android:layout_weight="2.3"
        app:cardCornerRadius="20dp"
        app:cardElevation="0dp"
        app:cardBackgroundColor="@color/glass_background"
        app:strokeColor="@color/glass_stroke"
        app:strokeWidth="1dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingVertical="20dp"
            android:layout_margin="16dp">

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/toggle_group_choice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:checkedButton="@+id/choice1"
                android:gravity="center"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@id/harakat_toggle_group">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/choice1"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="همزة محققة"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/choice2"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="همزة مسهلة"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/harakat_toggle_group"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:checkedButton="@+id/radioButtonFatha"
                app:singleSelection="true"
                app:selectionRequired="true"
                app:layout_constraintTop_toBottomOf="@+id/toggle_group_choice"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioButtonFatha"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:text="فتحة"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioButtonThama"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:text="ضمة"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioButtonKasra"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:text="كسرة"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/radioButtonSokoun"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:insetLeft="0dp"
                    android:insetRight="0dp"
                    android:text="سكون"
                    android:textColor="@color/toggle_button_text_color"
                    android:textSize="16sp"
                    app:backgroundTint="@color/toggle_button_background_tint"
                    app:strokeColor="@color/primary"
                    app:cornerRadius="12dp" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <LinearLayout
                android:id="@+id/linearLayoutSeek"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@+id/harakat_toggle_group"
                app:layout_constraintBottom_toTopOf="@+id/message"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="8dp"
                    android:text="تكرار:"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:max="1000"
                    android:minHeight="48dp"
                    android:maxHeight="12dp"
                    android:progress="50"
                    android:progressDrawable="@drawable/custom_seekbar_track"
                    android:thumb="@drawable/custom_seekbar_thumb"
                    android:splitTrack="false" />

                <EditText
                    android:id="@+id/repeat_horof"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/card_background"
                    android:gravity="center"
                    android:inputType="number"
                    android:minWidth="40dp"
                    android:paddingHorizontal="8dp"
                    android:text="50"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <TextView
                android:id="@+id/message"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:gravity="center"
                android:text="وليس بينه وبين تركه *** إلا رياضة امرئ بفكه"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:shadowColor="@color/white"
                android:outlineSpotShadowColor="@color/white"
                android:shadowRadius="10"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/linearLayoutSeek" />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/nav_view"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/glass_dark"
        app:elevation="0dp"
        app:itemIconSize="32dp"
        app:itemIconTint="@color/nav_item_color"
        app:itemTextColor="@color/nav_item_color"
        app:menu="@menu/bottom_nav_menu" />

</LinearLayout>