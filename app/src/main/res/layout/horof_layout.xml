<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/background"
    android:keepScreenOn="true"
    tools:context=".HorofActivity">

    <FrameLayout
        android:id="@+id/videoLayout1"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_centerHorizontal="true"
        android:layout_weight="2"
        android:layout_gravity="center"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:background="@drawable/rectangle"
        android:backgroundTint="@color/color2"
        android:padding="@dimen/_3sdp">

        <com.example.myapplication2.PlayStateVideoView
            android:id="@+id/HorofVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
    </FrameLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginEnd="@dimen/_8sdp"
        android:layout_marginStart="@dimen/_8sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:gravity="center"
        android:layout_weight="1"
        android:layoutDirection="rtl"
        android:orientation="horizontal"
        android:paddingVertical="@dimen/_10sdp">

        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:contentDescription="previous letre"
            android:onClick="previousHarf"
            android:backgroundTint="@color/color2"
            app:srcCompat="@android:drawable/ic_media_play" />
        <TextView
            android:id="@+id/harf"
            android:layout_width="@dimen/_50sdp"
            android:layout_height="@dimen/_70sdp"
            android:text="ء"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="@dimen/_50ssp"
            android:textStyle="bold" />
        <ImageButton
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="@dimen/_10sdp"
            android:contentDescription="next letre"
            android:onClick="nextHarf"
            android:rotation="180"
            android:backgroundTint="@color/color2"
            app:srcCompat="@android:drawable/ic_media_play" />
    </LinearLayout>
<androidx.cardview.widget.CardView
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_below="@+id/barrier"
    android:layout_weight="3"
    android:layout_margin="@dimen/_15sdp"
    app:cardBackgroundColor="#98b0a8"
    app:cardCornerRadius="@dimen/_30sdp"
    app:cardElevation="5dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/color1"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="@dimen/_10sdp">
            <RadioGroup
                android:id="@+id/radio_group1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:orientation="horizontal">
                <RadioButton
                    android:id="@+id/choice2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="همزة مسهلة"
                    android:layoutDirection="rtl"
                    android:textColor="@color/white"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:buttonTint="@color/white"
                    android:textSize="@dimen/_12ssp"/>
                <RadioButton
                    android:id="@+id/choice1"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="همزة محققة"
                    android:checked="true"
                    android:textColor="@color/white"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layoutDirection="rtl"
                    android:buttonTint="@color/white"
                    android:textSize="@dimen/_12ssp"/>
            </RadioGroup>
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal">

                <RadioGroup
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center_horizontal"
                    android:layoutDirection="rtl"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/radioButtonFatha"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginEnd="@dimen/_1sdp"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:layout_weight="1"
                        android:buttonTint="@color/white"
                        android:checked="true"
                        android:layoutDirection="rtl"
                        android:text="فتحة"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp" />

                    <RadioButton
                        android:id="@+id/radioButtonThama"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginEnd="@dimen/_1sdp"
                        android:layout_marginStart="@dimen/_1sdp"
                        android:layout_weight="1"
                        android:buttonTint="@color/white"
                        android:layoutDirection="rtl"
                        android:text="ضمة"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp" />

                    <RadioButton
                        android:id="@+id/radioButtonKasra"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginEnd="@dimen/_1sdp"
                        android:layout_marginStart="@dimen/_1sdp"
                        android:layout_weight="1"
                        android:buttonTint="@color/white"
                        android:layoutDirection="rtl"
                        android:text="كسرة"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp" />

                    <RadioButton
                        android:id="@+id/radioButtonSokoun"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="right"
                        android:layout_marginEnd="@dimen/_5sdp"
                        android:layout_marginStart="@dimen/_1sdp"
                        android:layout_weight="1"
                        android:buttonTint="@color/white"
                        android:layoutDirection="rtl"
                        android:text="سكون"
                        android:textColor="@color/white"
                        android:textSize="@dimen/_12ssp" />

                </RadioGroup>

            </LinearLayout>
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layoutDirection="rtl">

                <TextView
                    android:id="@+id/textView3"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_column="0"
                    android:layout_marginRight="@dimen/_10sdp"
                    android:layout_gravity="center"
                    android:layout_row="0"
                    android:textAlignment="center"
                    android:text="مرات التكرار"
                    android:textColor="@color/white"
                    android:textSize="@dimen/_12ssp" />

                <SeekBar
                    android:id="@+id/seekBar"
                    style="@android:style/Widget.SeekBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_row="0"
                    android:layout_column="1"
                    android:layout_gravity="center|fill"
                    android:max="10000"
                    android:min="0"
                    android:progress="3"
                    android:progressBackgroundTint="@color/white"
                    android:progressTint="@color/color2"
                    android:thumb="@color/design_default_color_error" />

                <TextView
                    android:id="@+id/repeat"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="wrap_content"
                    android:text="50"
                    android:gravity="center"
                    android:layoutDirection="rtl"
                    android:layout_marginLeft="@dimen/_10sdp"
                    android:textColor="@color/white"
                    android:foregroundGravity="right"
                    android:textSize="@dimen/_13ssp" />
            </GridLayout>
        </LinearLayout>
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="3"
            android:background="@color/color2"
            android:orientation="vertical">

            <TextView
                android:id="@+id/message"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginBottom="@dimen/_10sdp"
                android:layout_marginLeft="@dimen/_8sdp"
                android:layout_marginRight="@dimen/_8sdp"
                android:layout_marginTop="@dimen/_10sdp"
                android:layout_weight="1"
                android:gravity="center"
                android:lineSpacingExtra="16sp"
                android:text="وليس بينه وبين تركه *** إلا رياضة امرئ بفكه"
                android:textAlignment="center"
                android:textColor="@color/white"
                android:textSize="@dimen/_13ssp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>


</LinearLayout>
