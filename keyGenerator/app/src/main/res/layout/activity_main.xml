<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:background="#DC313335"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/id"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="0dp"
        android:layout_marginTop="0dp"
        android:gravity="center"
        android:text="key Generator"
        android:textColor="@color/white"
        android:textSize="35dp" />

    <EditText
        android:id="@+id/id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/editTextTextPersonName"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="20dp"
        android:layout_marginStart="10dp"
        android:layout_toEndOf="@+id/editTextTextPersonName2"
        android:background="@color/white"
        android:gravity="center"
        android:hint="رقم الجهاز"
        android:inputType="text"
        android:textColor="@color/black"
        android:textColorHint="#8E8686"
        android:textSize="30sp" />

    <TextView
        android:id="@+id/editTextTextPersonName"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="20dp"
        android:enabled="true"
        android:gravity="center"
        android:inputType="none"
        android:text="id"
        android:textColor="@color/white"
        android:textSize="30sp" />

    <TextView
        android:id="@+id/key"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBaseline="@id/editTextTextPersonName2"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/id"
        android:layout_marginEnd="20dp"
        android:layout_marginStart="10dp"
        android:layout_marginTop="60dp"
        android:layout_toEndOf="@+id/editTextTextPersonName2"
        android:background="@color/white"
        android:gravity="center"
        android:inputType="none"
        android:selectAllOnFocus="true"
        android:singleLine="true"
        android:text=""
        android:textColor="@color/black"
        android:textIsSelectable="true"
        android:textSize="30sp" />

    <TextView
        android:id="@+id/editTextTextPersonName2"
        android:layout_width="70dp"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_below="@+id/editTextTextPersonName"
        android:layout_marginStart="20dp"
        android:layout_marginTop="60dp"
        android:gravity="center"
        android:inputType="none"
        android:text="key"
        android:textColor="@color/white"
        android:textSize="30sp" />

    <Button
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextTextPersonName2"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="60dp"
        android:onClick="calculate"
        android:text="أحسب"
        android:textColor="@color/white"
        android:textSize="20dp"
        app:backgroundTint="#063961" />

</RelativeLayout>